[Unit]
Description=Leadfind FastAPI API
After=network.target

[Service]
Type=simple
User=openclaw
WorkingDirectory=/home/openclaw/.openclaw/workspace/leadfind
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/openclaw/.openclaw/workspace/leadfind/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8021
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
